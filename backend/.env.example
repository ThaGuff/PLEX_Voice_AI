# ── Database (Railway PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/aria_db

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
FRONTEND_URL=https://your-railway-app.up.railway.app

# ── Twilio ────────────────────────────────────────────────────────────────────
# These are also stored per-org in the DB.
# These are the PLATFORM-LEVEL defaults (for sending platform notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+12568002700

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM=noreply@ariaplatform.io

# ── Optional: Stripe (for billing) ───────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
